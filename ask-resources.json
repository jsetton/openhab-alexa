{
  "askcliResourcesVersion": "2020-03-31",
  "profiles": {
    "default": {
      "skillMetadata": {
        "src": "./skill-package"
      },
      "code": {
        "default": {
          "src": "./lambda/smarthome"
        }
      },
      "skillInfrastructure": {
        "type": "@ask-cli/cfn-deployer",
        "userConfig": {
          "runtime": "nodejs12.x",
          "handler": "index.handler",
          "templatePath": "./infrastructure/cfn-deployer/skill-stack.yml",
          "cfn": {
            "parameters": {
              "LambdaFunctionName": "alexa-openhab",
              "LambdaDescription": "openHAB Alexa Smart Home Skill",
              "LambdaMemorySize": 128,
              "LambdaTimeout": 10
            }
          }
        }
      }
    }
  }
}